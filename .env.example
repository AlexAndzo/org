# Call Match Package 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========== 数据库配置 ==========
DB_HOST=your-db-host.com
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=sdr_backend

# ========== CSV 文件路径 ==========
# CSV_FILE=/path/to/your/company_openings.csv

# ========== LLM 配置 ==========
LLM_API_KEY=your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# ========== 阈值配置（可选） ==========
# USAGE_THRESHOLD=50
# OPENING_THRESHOLD=70
# ANSWER_THRESHOLD=70
